-- The "Activated" Button Engine
local function AddButton(text, yPos, callback)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0, 210, 0, 45)
    btn.Position = UDim2.new(0, 20, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    -- Mobile-Proof Animation
    btn.Activated:Connect(function()
        local tween = TS:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 200, 0, 40)})
        tween:Play()
        callback()
        task.wait(0.2)
        TS:Create(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 210, 0, 45)}):Play()
    end)
end

