local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local TS = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local LocalPlayer = Players.LocalPlayer

-- UI ENGINE
local ScreenGui = Instance.new("ScreenGui", CoreGui)
ScreenGui.Name = "ENI_Master"
ScreenGui.DisplayOrder = 9999

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 250, 0, 400)
Main.Position = UDim2.new(0.5, -125, 0.5, -200)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 12)

-- ROLE ESP ENGINE (Integrated)
RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local role = (p.Character:FindFirstChild("Knife") and "Murderer") or (p.Character:FindFirstChild("Gun") and "Sheriff") or nil
            local h = p.Character:FindFirstChild("RoleHighlight") or Instance.new("Highlight", p.Character)
            h.Name = "RoleHighlight"
            h.Enabled = (role ~= nil)
            h.FillColor = (role == "Murderer" and Color3.fromRGB(255, 0, 0)) or (role == "Sheriff" and Color3.fromRGB(0, 150, 255)) or Color3.fromRGB(255, 255, 255)
        end
    end
end)

-- BUTTON ENGINE
local function AddButton(text, yPos, callback)
    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0, 210, 0, 45)
    btn.Position = UDim2.new(0, 20, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.Activated:Connect(function()
        local t = TS:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, 190, 0, 40)})
        t:Play(); callback(); task.wait(0.1); TS:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, 210, 0, 45)}):Play()
    end)
end

-- CONTROLS
AddButton("KILL ALL", 20, function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            RS.MurderHit:FireServer(p.Character.HumanoidRootPart)
        end
    end
end)

